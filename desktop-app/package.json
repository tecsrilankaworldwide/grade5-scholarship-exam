{
  "name": "grade5-exam-desktop",
  "version": "2.0.0",
  "description": "Grade 5 Scholarship Exam Platform - Desktop Application",
  "main": "main.js",
  "author": "TEC Sri Lanka Worldwide (Pvt.) Ltd",
  "license": "Proprietary",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist-win": "electron-builder --win",
    "dist-mac": "electron-builder --mac",
    "dist-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.tecsrilanka.grade5exam",
    "productName": "Grade 5 Scholarship Exam Platform",
    "copyright": "Copyright © 2026 TEC Sri Lanka Worldwide (Pvt.) Ltd",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "backend/**/*",
      "frontend/build/**/*",
      "!backend/venv/**/*",
      "!backend/__pycache__/**/*",
      "!**/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "portable_mongodb",
        "to": "portable_mongodb"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Grade 5 Exam Platform"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "fix-path": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
